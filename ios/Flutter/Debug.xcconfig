#include? "Pods/Target Support Files/Pods-Runner/Pods-Runner.debug.xcconfig"
#include "Generated.xcconfig"

// Break Xcode 16 build cycle: extension target + CocoaPods scripts + AppIntents
// metadata extraction triggers a dependency loop through Info.plist processing.
// We don't ship AppIntents, so disabling the metadata step removes the loop.
APPINTENTS_DEPLOYMENT_POSTPROCESSING = NO
